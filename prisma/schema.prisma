generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

model Company {
  id                 String              @id @default(cuid())
  name               String              @unique
  slug               String              @unique
  domain             String?
  logo               String?
  isActive           Boolean             @default(true)
  lastAuditHash      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  auditLogs          AuditLog[]
  conflictLogs       ConflictLog[]
  emailAccounts      EmailAccount[]
  emailAttachments   EmailAttachment[]
  emailMessages      EmailMessage[]
  emailQueue         EmailQueue[]
  emailSendAudits    EmailSendAudit[]
  emailThreadLeads   EmailThreadLead[]
  emailThreads       EmailThread[]
  emailWebhookStates EmailWebhookState[]
  leads              Lead[]
  rolePresets        RolePreset[]
  savedViews         SavedView[]
  sessions           Session[]
  syncCheckpoints    SyncCheckpoint[]
  syncQueue          SyncQueue[]
  users              User[]
  memberships        CompanyMembership[]
  invitations        Invitation[]

  @@map("companies")
}

model User {
  id                    String              @id @default(cuid())
  companyId             String
  username              String
  name                  String
  email                 String
  password              String
  role                  String              @default("SALES_EXECUTIVE")
  isActive              Boolean             @default(true)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  lastLoginAt           DateTime?
  passwordLastChangedAt DateTime?
  failedLoginAttempts   Int                 @default(0)
  lockedUntil           DateTime?
  stickyLeadTableHeader Boolean             @default(true)
  rolePresetId          String?
  customPermissions     String?
  auditLogs             AuditLog[]          @relation("PerformedBy")
  emailAccounts         EmailAccount[]
  emailMessages         EmailMessage[]
  emailSendAudits       EmailSendAudit[]
  emailThreads          EmailThread[]
  emailWebhookStates    EmailWebhookState[]
  leads                 Lead[]              @relation("AssignedTo")
  createdLeads          Lead[]              @relation("CreatedBy")
  sessions              Session[]
  company               Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships           CompanyMembership[]
  sentInvitations       Invitation[]        @relation("UserInvitations")

  @@unique([companyId, username])
  @@unique([companyId, email])
  @@index([companyId])
  @@map("users")
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  token       String           @unique
  companyId   String
  role        CompanyRole
  invitedById String
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("UserInvitations", fields: [invitedById], references: [id])

  @@index([companyId])
  @@index([email])
  @@index([token])
  @@map("invitations")
}

model CompanyMembership {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@map("company_memberships")
}

model Session {
  id             String   @id @default(cuid())
  companyId      String
  userId         String
  token          String   @unique
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime @default(now())
  expiresAt      DateTime
  lastActivityAt DateTime @default(now())
  isValid        Boolean  @default(true)
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model Lead {
  id               String            @id @default(cuid())
  companyId        String
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  companyName      String?
  source           String?
  status           String            @default("NEW")
  notes            String?
  customFields     String?           @default("{}")
  assignedToId     String?
  createdById      String?
  syncVersion      Int               @default(0)
  lastSyncedAt     DateTime?
  isDirty          Boolean           @default(false)
  syncStatus       String            @default("SYNCED")
  deviceId         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  statusUpdatedAt  DateTime?
  convertedAt      DateTime?
  emailThreadLinks EmailThreadLead[]
  assignedTo       User?             @relation("AssignedTo", fields: [assignedToId], references: [id])
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdBy        User?             @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([assignedToId])
  @@index([isDirty])
  @@index([syncStatus])
  @@index([companyId, status])
  @@index([companyId, assignedToId])
  @@map("leads")
}

model AuditLog {
  id              String   @id @default(cuid())
  companyId       String
  actionType      String
  entityType      String?
  entityId        String?
  description     String
  performedById   String?
  performedByName String?
  ipAddress       String?
  userAgent       String?
  sessionId       String?
  beforeValue     String?  @default("{}")
  afterValue      String?  @default("{}")
  changesSummary  String?
  metadata        String?  @default("{}")
  previousHash    String?
  hash            String?
  createdAt       DateTime @default(now())
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  performedBy     User?    @relation("PerformedBy", fields: [performedById], references: [id])

  @@index([companyId])
  @@index([actionType])
  @@index([entityType, entityId])
  @@index([performedById])
  @@index([createdAt])
  @@index([companyId, actionType])
  @@index([companyId, createdAt])
  @@map("audit_logs")
}

model SavedView {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  config      String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("saved_views")
}

model RolePreset {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  description String?
  permissions String
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])
  @@index([companyId])
  @@map("role_presets")
}

model EmailAccount {
  id                    String    @id @default(cuid())
  companyId             String
  userId                String
  provider              String
  emailAddress          String
  providerAccountId     String?
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  status                String    @default("ACTIVE")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  company               Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([companyId])
  @@index([userId, provider])
  @@index([emailAddress])
  @@index([companyId, userId])
  @@map("email_accounts")
}

model EmailThread {
  id               String            @id @default(cuid())
  companyId        String
  userId           String
  provider         String
  providerThreadId String
  subject          String?
  snippet          String?
  lastMessageAt    DateTime?
  unreadCount      Int               @default(0)
  hasAttachments   Boolean           @default(false)
  folder           String?
  leadId           String?
  syncVersion      Int               @default(0)
  isDirty          Boolean           @default(false)
  lastSyncedAt     DateTime?
  syncStatus       String            @default("SYNCED")
  deviceId         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  messages         EmailMessage[]
  sendAudits       EmailSendAudit[]
  threadLeads      EmailThreadLead[]
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, providerThreadId])
  @@index([companyId])
  @@index([userId, provider, providerThreadId])
  @@index([lastMessageAt])
  @@index([leadId])
  @@index([isDirty])
  @@index([companyId, userId])
  @@index([companyId, isDirty])
  @@map("email_threads")
}

model EmailMessage {
  id                String            @id @default(cuid())
  companyId         String
  threadId          String
  userId            String
  provider          String
  providerMessageId String
  from              String?
  to                String?
  cc                String?
  bcc               String?
  subject           String?
  snippet           String?
  sentAt            DateTime?
  isRead            Boolean           @default(false)
  hasAttachments    Boolean           @default(false)
  attachmentsMeta   String?
  syncVersion       Int               @default(0)
  isDirty           Boolean           @default(false)
  lastSyncedAt      DateTime?
  syncStatus        String            @default("SYNCED")
  deviceId          String?
  createdAt         DateTime          @default(now())
  attachments       EmailAttachment[]
  company           Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  thread            EmailThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, providerMessageId])
  @@index([companyId])
  @@index([threadId])
  @@index([userId])
  @@index([sentAt])
  @@index([isDirty])
  @@index([companyId, userId])
  @@index([companyId, isDirty])
  @@map("email_messages")
}

model EmailAttachment {
  id                   String       @id @default(cuid())
  companyId            String
  messageId            String
  filename             String?
  mimeType             String?
  size                 Int?
  providerAttachmentId String?
  company              Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  message              EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([messageId])
  @@map("email_attachments")
}

model EmailWebhookState {
  id             String   @id @default(cuid())
  companyId      String
  userId         String
  provider       String
  lastHistoryId  String?
  lastDeltaToken String?
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, provider])
  @@index([companyId, userId])
  @@index([companyId])
  @@map("email_webhook_state")
}

model EmailSendAudit {
  id        String       @id @default(cuid())
  companyId String
  userId    String
  threadId  String?
  provider  String
  to        String?
  subject   String?
  sentAt    DateTime?
  messageId String?
  createdAt DateTime     @default(now())
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  thread    EmailThread? @relation(fields: [threadId], references: [id])
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([threadId])
  @@index([companyId, userId])
  @@map("email_send_audit")
}

model EmailThreadLead {
  id        String      @id @default(cuid())
  companyId String
  threadId  String
  leadId    String
  createdAt DateTime    @default(now())
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead      Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  thread    EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([companyId, threadId, leadId])
  @@index([companyId])
  @@index([threadId])
  @@index([leadId])
  @@map("email_thread_leads")
}

model SyncQueue {
  id         String    @id @default(cuid())
  companyId  String
  entityType String
  entityId   String
  operation  String
  payload    String
  createdAt  DateTime  @default(now())
  syncedAt   DateTime?
  retryCount Int       @default(0)
  lastError  String?
  priority   Int       @default(0)
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([syncedAt])
  @@index([operation])
  @@index([priority])
  @@index([entityType])
  @@index([companyId, syncedAt])
  @@index([companyId, operation])
  @@map("sync_queue")
}

model EmailQueue {
  id            String    @id @default(cuid())
  companyId     String
  userId        String
  to            String
  subject       String
  body          String
  cc            String?
  bcc           String?
  linkedLeadId  String?
  fromAccountId String?
  attachments   String?
  createdAt     DateTime  @default(now())
  syncedAt      DateTime?
  status        String    @default("DRAFT")
  error         String?
  retryCount    Int       @default(0)
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([syncedAt])
  @@index([companyId, status])
  @@index([companyId, userId])
  @@map("email_queue")
}

model ConflictLog {
  id            String    @id @default(cuid())
  companyId     String
  entityType    String
  entityId      String
  localVersion  Int
  serverVersion Int
  resolution    String?
  resolvedAt    DateTime?
  localData     String
  serverData    String
  createdAt     DateTime  @default(now())
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([entityType, entityId])
  @@index([resolvedAt])
  @@index([companyId, entityType])
  @@map("conflict_logs")
}

model SyncCheckpoint {
  id              String    @id @default(cuid())
  companyId       String
  entityType      String
  lastSyncVersion Int       @default(0)
  lastSyncTime    DateTime?
  deviceId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, entityType, deviceId])
  @@index([companyId])
  @@index([entityType])
  @@map("sync_checkpoints")
}
